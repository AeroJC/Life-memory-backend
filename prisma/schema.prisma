generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  name      String
  email     String   @unique
  phone     String?
  avatar    String   @default("")
  password  String?
  createdAt DateTime @default(now())

  emailVerified         Boolean   @default(false)
  verificationCode      String?
  verificationCodeExpiry DateTime?
  resetCode             String?
  resetCodeExpiry       DateTime?

  vaultCode               String?
  hiddenSpaceIds          Json    @default("[]")
  vaultResetCode          String?
  vaultResetCodeExpiry    DateTime?

  ownedSpaces  Space[]       @relation("SpaceOwner")
  memberships  SpaceMember[]
  joinRequests JoinRequest[]
  memories     Memory[]
  notifications         Notification[] @relation("NotificationRecipient")
  notificationsTriggered Notification[] @relation("NotificationActor")
}

model Space {
  id          String   @id
  title       String
  coverImage        String   @default("")
  coverImageOffsetX Float    @default(50)
  coverImageOffsetY Float    @default(50)
  coverImageScale   Float    @default(1)
  coverEmoji        String   @default("✨")
  coverIcon         String   @default("")
  coverColor        String   @default("")
  type        String   @default("personal")
  inviteCode  String?  @unique
  description String   @default("")
  createdAt   DateTime @default(now())

  createdById String
  createdBy      User            @relation("SpaceOwner", fields: [createdById], references: [id])
  members        SpaceMember[]
  joinRequests   JoinRequest[]
  pendingInvites PendingInvite[]
  memories       Memory[]
  notifications  Notification[]
}

model SpaceMember {
  id         String @id @default(cuid())
  role       String @default("member")
  status     String @default("active")
  permission String @default("edit")
  joinedAt   String

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([userId])
  @@index([spaceId])
}

model JoinRequest {
  id          String @id @default(cuid())
  requestedAt String

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([userId])
  @@index([spaceId])
}

model PendingInvite {
  id        String   @id @default(cuid())
  email     String
  spaceId   String
  invitedBy String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([email, spaceId])
  @@index([email])
  @@index([spaceId])
}

model Memory {
  id        String   @id
  title     String
  date      String
  endDate   String?
  photos    Json     @default("[]")
  story     String
  location  String?
  tags      Json?
  reactions Json     @default("{}")
  visibleTo Json?
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id])
  spaceId     String
  space       Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  substories  SubStory[]

  @@index([spaceId])
  @@index([createdById])
}

model SubStory {
  id         String  @id
  date       String
  type       String  @default("text")
  title      String?
  content    String?
  photos     Json?
  caption    String?
  canvasData Json?
  audioUrl   String?
  videoUrl   String?
  textStyle  String?
  titleStyle String?

  memoryId String
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // 'new_memory' | 'new_moment' | 'new_member' | 'reaction'
  message   String
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  actorId   String   // user who triggered the notification
  actor     User     @relation("NotificationActor", fields: [actorId], references: [id])
  targetId  String?  // memoryId or substoryId
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String     // user who receives the notification
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, spaceId])
  @@index([spaceId])
}

model Feedback {
  id        String   @id @default(cuid())
  type      String   // 'suggestion' | 'bug' | 'complaint'
  message   String
  userId    String
  userName  String
  userEmail String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}
